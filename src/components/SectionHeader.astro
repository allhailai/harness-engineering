---
// Reusable section header — supports optional phase badge
export interface Props {
  label: string;
  title: string;
  subtitle?: string;
  phase?: number;       // if set, renders the numbered phase badge
  complete?: boolean;   // shows "✓ Complete" status badge when true
}

const { label, title, subtitle, phase, complete = false } = Astro.props;
---

<div class="section-header">
  {phase !== undefined && (
    <div class="phase-badge">
      <div class="phase-number">{phase}</div>
      {complete && <div class="status-badge">✓ Complete</div>}
    </div>
  )}
  <div class="section-title-group">
    <div class="section-label">{label}</div>
    <h2 class="section-title">{title}</h2>
    {subtitle && <p class="section-subtitle">{subtitle}</p>}
  </div>
</div>

<style>
  .section-header {
    display: flex;
    align-items: flex-start;
    gap: 20px;
    margin-bottom: 32px;
  }
  .phase-badge {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
  }
  .phase-number {
    width: 52px;
    height: 52px;
    border-radius: 14px;
    background: linear-gradient(135deg, var(--accent), var(--accent-dark));
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    font-weight: 800;
    color: white;
  }
  .status-badge {
    margin-top: 8px;
    display: inline-flex;
    align-items: center;
    gap: 4px;
    background: var(--green-light);
    color: #15803d;
    border: 1px solid #bbf7d0;
    border-radius: 100px;
    padding: 3px 10px;
    font-size: 10.5px;
    font-weight: 700;
    white-space: nowrap;
  }
  .section-title-group {
    flex: 1;
  }
  .section-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 6px;
  }
  .section-title {
    font-size: clamp(22px, 3vw, 30px);
    font-weight: 700;
    color: var(--content-text);
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin-bottom: 8px;
  }
  .section-subtitle {
    font-size: 15px;
    color: var(--content-muted);
    line-height: 1.5;
  }
</style>
